[Unit]
Description=DTD Atlas FastAPI Service
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/srv/dtd_platform
Environment=DTD_DB_PATH=/srv/dtd_data/dtd_network.sqlite
ExecStart=/srv/dtd_platform/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8787
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
